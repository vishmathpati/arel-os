{
  "name": "rlo",
  "version": "0.1.0",
  "description": "Installer and service manager for a self-hosted Arel OS on macOS.",
  "type": "module",
  "bin": {
    "rlo": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
