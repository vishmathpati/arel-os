<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.arelos.web</string>
  <key>ProgramArguments</key>
  <array><string>{{INSTALL_DIR}}/scripts/service/run-web.sh</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>ThrottleInterval</key><integer>10</integer>
  <key>WorkingDirectory</key><string>{{INSTALL_DIR}}</string>
  <key>StandardOutPath</key><string>{{INSTALL_DIR}}/logs/service/web.log</string>
  <key>StandardErrorPath</key><string>{{INSTALL_DIR}}/logs/service/web.log</string>
</dict>
</plist>
