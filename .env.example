# Vercel AI Gateway key used for recipes/Engine calls
AI_GATEWAY_API_KEY=

# Primary model identifier the Arel Engine uses
ARELOS_ENGINE_MODEL=

# Fallback model identifier if the primary Engine model is unavailable
ARELOS_ENGINE_FALLBACK=

# Port the local vault server listens on (default 5274)
ARELOS_VAULT_PORT=5274

# Optional: keyring backend for Google Workspace CLI credential storage (advanced Gmail finance sync)
GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=

# Optional: path to Google Workspace CLI credentials file (advanced Gmail finance sync)
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=
