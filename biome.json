{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": ["node_modules", "dist"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "include": ["src/shared/components/ui/**", "src/shared/components/editor/**"],
      "linter": {
        "rules": {
          "correctness": { "useExhaustiveDependencies": "off" },
          "complexity": { "noForEach": "off" },
          "suspicious": { "noArrayIndexKey": "off" },
          "a11y": {
            "useFocusableInteractive": "off",
            "noLabelWithoutControl": "off",
            "noSvgWithoutTitle": "off",
            "useKeyWithClickEvents": "off",
            "useKeyWithMouseEvents": "off",
            "useMediaCaption": "off",
            "useSemanticElements": "off",
            "noAutofocus": "off"
          }
        }
      }
    }
  ]
}
